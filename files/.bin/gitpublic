#!/usr/bin/env zsh
# Set local git [user] config to the public identity if not already set.
# Usage: gitpublic [-f]
#   -f  overwrite existing local user.* values

force=false
while getopts "fh" opt; do
  case $opt in
    f) force=true ;;
    h) echo "Usage: gitpublic [-f]"; exit 0 ;;
    *) echo "Usage: gitpublic [-f]" >&2; exit 1 ;;
  esac
done

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  echo "Not a git repository." >&2
  exit 1
fi

public_name="Gonçalo Sousa"
public_email="sousago@gmail.com"
public_signingkey="/Users/goncalo.sousa/.ssh/id_ed25519-sousago.pub"

existing_email=$(git config --local --get user.email 2>/dev/null)
if [[ -n "$existing_email" && "$force" != true ]]; then
  echo "Local user.email already set to '$existing_email'. Use -f to overwrite."
  exit 0
fi

git config --local user.name "$public_name"
git config --local user.email "$public_email"
git config --local user.signingkey "$public_signingkey"

echo "Set local [user] to:"
echo "  name       = $public_name"
echo "  email      = $public_email"
echo "  signingkey = $public_signingkey"
